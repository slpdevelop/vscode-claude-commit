{
  "name": "claude-commit",
  "displayName": "Claude Commit Message Generator",
  "description": "Generate commit messages using Claude AI (Anthropic API or AWS Bedrock)",
  "version": "0.2.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "claude",
    "commit message"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-commit.generate",
        "title": "Generate Commit Message with Claude",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "claude-commit.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "Claude Commit",
      "properties": {
        "claudeCommit.provider": {
          "type": "string",
          "default": "anthropic",
          "enum": [
            "anthropic",
            "bedrock"
          ],
          "enumDescriptions": [
            "Direct Anthropic API (requires API key)",
            "AWS Bedrock (requires AWS credentials)"
          ],
          "description": "Claude API provider"
        },
        "claudeCommit.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (only for 'anthropic' provider)",
          "markdownDescription": "Your Anthropic API key. Get one at https://console.anthropic.com/. Only needed when provider is 'anthropic'."
        },
        "claudeCommit.awsRegion": {
          "type": "string",
          "default": "us-east-1",
          "description": "AWS region for Bedrock (only for 'bedrock' provider)",
          "markdownDescription": "AWS region where Bedrock is available. Common: us-east-1, us-west-2, eu-west-1. Only needed when provider is 'bedrock'."
        },
        "claudeCommit.awsProfile": {
          "type": "string",
          "default": "",
          "description": "AWS profile name (optional, for 'bedrock' provider)",
          "markdownDescription": "AWS CLI profile to use. Leave empty to use default credentials. Only for 'bedrock' provider."
        },
        "claudeCommit.model": {
          "type": "string",
          "default": "claude-haiku-4-5-20251001",
          "enum": [
            "claude-haiku-4-5-20251001",
            "claude-sonnet-4-6",
            "claude-opus-4-8"
          ],
          "enumDescriptions": [
            "Fast and economical - ideal for commit messages",
            "Advanced model for complex changes",
            "Most powerful model"
          ],
          "description": "Claude model to use"
        },
        "claudeCommit.useConventionalCommits": {
          "type": "boolean",
          "default": true,
          "description": "Use Conventional Commits format (feat:, fix:, etc.)"
        },
        "claudeCommit.analyzeAllChanges": {
          "type": "boolean",
          "default": true,
          "description": "Analyze all changes (not just staged)"
        },
        "claudeCommit.maxDiffSize": {
          "type": "number",
          "default": 50000,
          "description": "Maximum diff size in characters to send to Claude"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.45.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1066.0",
    "@aws-sdk/credential-providers": "^3.1066.0"
  }
}
